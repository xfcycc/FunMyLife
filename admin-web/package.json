{
  "name": "ruoyi-vue-plus",
  "version": "2.1.0",
  "description": "结合了 RuoYi-Vue-Plus 的强大后端功能和 Soybean Admin 的现代化前端特性，为开发者提供了完整的企业管理解决方案。",
  "keywords": [
    "RuoYi-Vue-Plus",
    "Soybean Admin",
    "TypeScript",
    "UnoCSS",
    "Vite7",
    "Vue3 admin ",
    "ant-design-vue v4",
    "naive-ui",
    "naive-ui-admin",
    "vue-admin-template"
  ],
  "homepage": "https://docs.ruoyi.xlsea.cn",
  "bugs": {
    "url": "https://gitee.com/xlsea/ruoyi-plus-soybean/issues"
  },
  "license": "MIT",
  "author": {
    "name": "xlsea",
    "email": "m@xlsea.cn",
    "url": "https://gitee.com/xlsea"
  },
  "contributors": [
    {
      "name": "Elio",
      "email": "1983933789@qq.com",
      "url": "https://gitee.com/elio-an"
    }
  ],
  "repository": {
    "url": "https://gitee.com/xlsea/ruoyi-plus-soybean.git"
  },
  "type": "module",
  "scripts": {
    "build": "vite build --mode prod",
    "build:dev": "vite build --mode dev",
    "build:test": "vite build --mode test",
    "cleanup": "sa cleanup",
    "commit": "sa git-commit",
    "commit:zh": "sa git-commit -l=zh-cn",
    "dev": "vite --mode dev",
    "dev:prod": "vite --mode prod",
    "dev:test": "vite --mode test",
    "fmt": "oxfmt",
    "gen-route": "sa gen-route",
    "lint": "oxlint --fix && eslint --fix .",
    "prepare": "simple-git-hooks",
    "preview": "vite preview",
    "release": "sa release",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "update-pkg": "sa update-pkg"
  },
  "dependencies": {
    "@better-scroll/core": "2.5.1",
    "@iconify/vue": "5.0.0",
    "@sa/axios": "workspace:*",
    "@sa/color": "workspace:*",
    "@sa/hooks": "workspace:*",
    "@sa/materials": "workspace:*",
    "@sa/utils": "workspace:*",
    "@types/streamsaver": "^2.0.5",
    "@vueuse/core": "14.2.1",
    "@wangeditor-next/editor": "^5.6.49",
    "@wangeditor-next/editor-for-vue": "^5.1.14",
    "clipboard": "2.0.11",
    "dayjs": "1.11.19",
    "defu": "6.1.4",
    "echarts": "6.0.0",
    "highlight.js": "^11.11.1",
    "jsencrypt": "^3.5.4",
    "json5": "2.2.3",
    "lucide-vue-next": "^1.0.0",
    "naive-ui": "2.44.1",
    "nprogress": "0.2.0",
    "pinia": "3.0.4",
    "streamsaver": "^2.0.6",
    "tailwind-merge": "3.5.0",
    "vue": "3.5.29",
    "vue-advanced-cropper": "^2.8.9",
    "vue-draggable-plus": "0.6.1",
    "vue-i18n": "11.3.0",
    "vue-router": "5.0.3"
  },
  "devDependencies": {
    "@elegant-router/vue": "0.3.8",
    "@iconify/json": "2.2.447",
    "@sa/scripts": "workspace:*",
    "@sa/uno-preset": "workspace:*",
    "@soybeanjs/eslint-config-vue": "^0.0.2",
    "@types/node": "25.3.5",
    "@types/nprogress": "0.2.3",
    "@vitejs/plugin-vue": "6.0.4",
    "@vitejs/plugin-vue-jsx": "5.1.4",
    "consola": "3.4.2",
    "eslint": "10.0.3",
    "kolorist": "1.8.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "sass": "1.97.3",
    "simple-git-hooks": "2.13.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "unocss": "^66.6.6",
    "unplugin-icons": "23.0.1",
    "unplugin-vue-components": "31.0.0",
    "vite": "7.3.1",
    "vite-plugin-progress": "0.0.7",
    "vite-plugin-svg-icons": "2.0.1",
    "vite-plugin-vue-devtools": "8.0.7",
    "vite-plugin-vue-transition-root-validator": "^0.1.0",
    "vue-tsc": "3.2.5"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm sa git-commit-verify",
    "pre-commit": "pnpm typecheck && pnpm lint && pnpm fmt && git diff --exit-code"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.5.0"
  },
  "website": "https://ruoyi.xlsea.cn"
}
